---
// 基础布局：仿 Steve Jobs Archive 的极简克制感
//   - 纯白底、纯黑字
//   - 标题衬线，正文系统字体
//   - 极重留白，hairline 分隔
//   - 文字滚动到视口时淡入上浮
interface Props {
  title: string;
  description?: string;
  image?: string;   // OG 图片路径，默认 /og-default.jpg
}

const { title, description = '思想名片', image = '/og-default.jpg' } = Astro.props;
const url = Astro.url;
const siteName = '思想名片';
const ogImage = url.origin + image;
const navItems = [
  { href: '/projects/', label: '项目' },
  { href: '/writing/', label: '写作' },
  { href: '/notes/', label: '随记' },
  { href: '/photos/', label: '照片' },
  { href: '/vlog/', label: 'vlog' },
];
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph / 社交分享卡片 -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={url.href} />
  </head>
  <body>
    <a href="#main" class="skip-link">跳到内容</a>

    <header class="site-header">
      <a href="/" class="logo" aria-label="首页">
        <span class="logo-mark" aria-hidden="true"></span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <ul>
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'nav-link',
                  { 'is-active': currentPath.startsWith(item.href) },
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-newsletter">
        <p class="footer-newsletter-text">订阅更新。有新项目或文章时，我会写邮件告诉你。</p>
        <a href="mailto:sacharn@163.com?subject=订阅思想名片更新" class="footer-button">邮件订阅</a>
      </div>
      <div class="footer-divider" aria-hidden="true"></div>
      <div class="footer-row">
        <a href="/about/" class="footer-link">关于</a>
        <a href="mailto:sacharn@163.com" class="footer-link">联系</a>
        <a href="#" class="footer-link" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">返回顶部</a>
      </div>
      <div class="footer-row footer-row-meta">
        <span>© {new Date().getFullYear()} 严树成</span>
      </div>
    </footer>

    <script>
      // 首屏 fade-in：分批错开，肉眼能看到“陆续出现”
      const allFade = document.querySelectorAll('[data-fade]');
      const scrollOnly = document.querySelectorAll('[data-fade].fade-on-scroll');
      const isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!isReduced) {
        allFade.forEach((el, i) => {
          if (el.classList.contains('fade-on-scroll')) return;
          setTimeout(() => el.classList.add('is-visible'), 400 + i * 400);
        });

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.05, rootMargin: '0px 0px -5% 0px' }
        );
        scrollOnly.forEach((el) => io.observe(el));
      } else {
        allFade.forEach((el) => el.classList.add('is-visible'));
      }

      // 懒加载图片淡入
      document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
        if (img.complete) return;
        img.style.opacity = '0';
        img.style.transition = 'opacity 800ms cubic-bezier(0.16, 1, 0.3, 1)';
        img.addEventListener('load', () => { img.style.opacity = '1'; }, { once: true });
      });

      // header 滚动时加 hairline 分隔
      const header = document.querySelector('.site-header');
      if (header) {
        const onScroll = () => {
          header.classList.toggle('is-scrolled', window.scrollY > 4);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
