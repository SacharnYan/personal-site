---
// 基础布局：所有页面共用
// 设计原则：仿 Steve Jobs Archive 的克制感
//   - 纯白底、纯黑字
//   - 标题用衬线（思源宋体 / Georgia fallback），正文用 system-ui
//   - 极重留白
//   - 文字滚动到视口时淡入
interface Props {
  title: string;
  description?: string;
  image?: string;   // OG 图片路径，默认 /photos/photo-01.jpg
}

const { title, description = '思想名片', image = '/og-default.jpg' } = Astro.props;
const url = Astro.url;
const siteName = '思想名片';
const ogImage = url.origin + image;
const navItems = [
  { href: '/projects/', label: '项目' },
  { href: '/writing/', label: '写作' },
  { href: '/photos/', label: '照片' },
  { href: '/vlog/', label: 'vlog' },
];
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph / 社交分享卡片 -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={url.href} />
  </head>
  <body>
    <a href="#main" class="skip-link">跳到内容</a>

    <header class="site-header">
      <a href="/" class="logo" aria-label="首页">
        <span class="logo-mark" aria-hidden="true"></span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <ul>
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'nav-link',
                  { 'is-active': currentPath.startsWith(item.href) },
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-row">
        <a href="/about/" class="footer-link">关于</a>
        <a href="mailto:sacharn@163.com" class="footer-link">联系</a>
      </div>
      <div class="footer-row footer-row-meta">
        <span>© {new Date().getFullYear()}</span>
        <a href="/" class="footer-link">返回顶部</a>
      </div>
    </footer>

    <script>
      // fade-in：分两阶段
      // 1) 立即：所有 [data-fade] 都先动画一次（不管在不在视口）—— 解决"首屏看不到动效"
      // 2) 滚动时：滚动到视口再触发动画（仅限"重要"元素，添加 .fade-on-scroll）
      // 这样首屏会有一次明显的渐入仪式感，滚动时也不会感觉"动效没了"

      const allFade = document.querySelectorAll('[data-fade]');
      const scrollOnly = document.querySelectorAll('[data-fade].fade-on-scroll');

      // 首屏：分批错开，让肉眼能看到"陆续出现"
      // 每个元素 1400ms 动画，错开 400ms
      // 上一个快完成时下一个才启动——像多米诺，不急
      allFade.forEach((el, i) => {
       if (el.classList.contains('fade-on-scroll')) return; // 滚动的后面再触发
       setTimeout(() => el.classList.add('is-visible'), 400 + i * 400);
      });

      // 滚动：仅给明确标 .fade-on-scroll 的元素做
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.05, rootMargin: '0px 0px -5% 0px' }
      );
      scrollOnly.forEach((el) => io.observe(el));

      // 图片懒加载完成后也触发淡入
      document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
        if (img.complete) return;
        img.style.opacity = '0';
        img.style.transition = 'opacity 800ms cubic-bezier(0.16, 1, 0.3, 1)';
        img.addEventListener(
          'load',
          () => {
            img.style.opacity = '1';
          },
          { once: true }
        );
      });

      // header 滚动时加 hairline 分隔
      const header = document.querySelector('.site-header');
      if (header) {
        const onScroll = () => {
          if (window.scrollY > 4) {
            header.classList.add('is-scrolled');
          } else {
            header.classList.remove('is-scrolled');
          }
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
