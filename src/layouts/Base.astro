---
// 基础布局：精确复刻 Steve Jobs Archive；双语化：中文在根路径，英文在 /en/ 镜像
import '@fontsource/playfair-display/400.css';
import '@fontsource/noto-serif-sc/400.css';
import { t, href, switchPath, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: Lang;
}

const { title, lang = 'zh' } = Astro.props;
const url = Astro.url;
const siteName = t(lang, 'site.name');
const description = Astro.props.description ?? t(lang, 'site.desc');
const ogImage = url.origin + (Astro.props.image ?? '/og-default.jpg');
const navItems = [
  { href: href(lang, '/projects/'), label: t(lang, 'nav.projects') },
  { href: href(lang, '/writing/'), label: t(lang, 'nav.writing') },
  { href: href(lang, '/notes/'), label: t(lang, 'nav.notes') },
  { href: href(lang, '/photos/'), label: t(lang, 'nav.photos') },
  { href: href(lang, '/vlog/'), label: t(lang, 'nav.vlog') },
];
const homeHref = href(lang, '/');
const aboutHref = href(lang, '/about/');
const otherPath = switchPath(lang, url.pathname);
const zhUrl = url.origin + (lang === 'zh' ? url.pathname : otherPath);
const enUrl = url.origin + (lang === 'en' ? url.pathname : otherPath);
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      /* 只在支持 classList 的浏览器里启用入场动画（主脚本是 ES5 经典脚本，不依赖 module）；
         更老的浏览器不标记 js，内容直接可见 */
      if ('classList' in document.documentElement) document.documentElement.classList.add('js');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="alternate icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={url.href} />
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />
  </head>
  <body data-toast-mail={t(lang, 'toast.mail')}>
    <a href="#main" class="skip-link">{t(lang, 'a11y.skip')}</a>

    <header class="site-header">
      <a href={homeHref} class="logo" aria-label={t(lang, 'a11y.home')}>
        <img src="/logo-variants/logo-spiral.svg" alt="" class="logo-mark" />
      </a>
      <button type="button" class="menu-toggle" aria-expanded="false" aria-controls="site-menu">
        Menu
        <svg class="menu-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
          <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </button>
    </header>

    <div class="menu-overlay" id="site-menu" hidden>
      <div class="menu-scrim"></div>
      <div class="menu-panel">
        <div class="menu-panel-head">
          <a href={homeHref} class="logo" aria-label={t(lang, 'a11y.home')}>
            <img src="/logo-variants/logo-spiral.svg" alt="" class="logo-mark" />
          </a>
          <button type="button" class="menu-close">Close</button>
        </div>
        <nav class="menu-nav" aria-label={t(lang, 'a11y.menu')}>
          <ul class="menu-list">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="menu-link">{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
        <ul class="menu-foot">
          <li><a href={aboutHref} class="menu-foot-link">{t(lang, 'foot.about')}</a></li>
          <li><a href="mailto:sacharn@163.com" class="menu-foot-link" data-mail="sacharn@163.com">{t(lang, 'foot.contact')}</a></li>
          <li><a href={otherPath} class="menu-foot-link menu-lang" aria-label={t(lang, 'lang.switchAria')} hreflang={lang === 'zh' ? 'en' : 'zh-CN'}>{t(lang, 'lang.switch')}</a></li>
        </ul>
      </div>
    </div>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-news">
        <p class="footer-news-text">{t(lang, 'foot.news')}</p>
        <a href={`mailto:sacharn@163.com?subject=${encodeURIComponent(t(lang, 'mail.subject'))}`} class="footer-arrow" aria-label={t(lang, 'foot.subscribe')} data-mail="sacharn@163.com">
          <svg width="16" height="12" viewBox="0 0 16 12" fill="none" aria-hidden="true">
            <path d="M1 6h13M10 1.5L14.5 6 10 10.5" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </a>
      </div>
      <div class="footer-base">
        <p class="footer-copy">{t(lang, 'foot.copy', { year })}</p>
        <ul class="footer-links">
          <li><a href={aboutHref} class="footer-link">{t(lang, 'foot.about')}</a></li>
          <li><a href="mailto:sacharn@163.com" class="footer-link" data-mail="sacharn@163.com">{t(lang, 'foot.contact')}</a></li>
          <li><a href="https://github.com/SacharnYan" class="footer-link" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
        <a href="#" class="footer-link footer-top" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">{t(lang, 'foot.top')}</a>
      </div>
    </footer>

    <script is:inline>
      /* 经典脚本（非 module）：任何支持 ES5 的浏览器都会执行，不依赖 Astro 打包与 module 支持。
         结构原则：淡入显示是最高优先级，放在最前并独立防护；
         任何后续逻辑（菜单/图片/视频）报错都不能影响内容显示。 */

      /* 1) 淡入显示（最高优先级）
            不用 IntersectionObserver：部分手机内核的 IO 会空回调（isIntersecting 全 false）
            或只回调一次后失效。改用 getBoundingClientRect + scroll 检测，ES5 时代即支持。 */
      (function () {
        try {
          var allFade = document.querySelectorAll('[data-fade]');
          if (!allFade.length) return;
          var isReduced = false;
          try { isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
          var showAll = function () {
            for (var i = 0; i < allFade.length; i++) allFade[i].classList.add('is-visible');
          };
          if (isReduced) { showAll(); return; }
          var reveal = function () {
            var vh = window.innerHeight || document.documentElement.clientHeight;
            for (var i = 0; i < allFade.length; i++) {
              var el = allFade[i];
              if (el.classList.contains('is-visible')) continue;
              /* top 进入视口 92% 线即显示；已滚过的（top 为负）也一并显示，
                 快速拖动进度条跳屏时中间内容不会残留隐藏 */
              if (el.getBoundingClientRect().top < vh * 0.92) el.classList.add('is-visible');
            }
          };
          reveal();
          var ticking = false;
          var onScroll = function () {
            if (ticking) return;
            ticking = true;
            setTimeout(function () { ticking = false; reveal(); }, 100);
          };
          window.addEventListener('scroll', onScroll);
          window.addEventListener('resize', onScroll);
          /* 兜底：2 秒后再全面检查一次 */
          setTimeout(reveal, 2000);
        } catch (e) {
          /* 任何异常：立即移除 js 标记，CSS 层恢复全部可见 */
          document.documentElement.classList.remove('js');
        }
      })();

      /* 2) SJA 式 Menu：全屏菜单开关 */
      try {
        var menuToggle = document.querySelector('.menu-toggle');
        var menuOverlay = document.querySelector('.menu-overlay');
        var menuClose = document.querySelector('.menu-close');
        var setMenu = function (open) {
          menuToggle.setAttribute('aria-expanded', String(open));
          if (open) {
            menuOverlay.hidden = false;
            requestAnimationFrame(function () {
              requestAnimationFrame(function () { menuOverlay.classList.add('is-open'); });
            });
            document.body.style.overflow = 'hidden';
          } else {
            menuOverlay.classList.remove('is-open');
            document.body.style.overflow = '';
            setTimeout(function () { menuOverlay.hidden = true; }, 450);
          }
        };
        menuToggle.addEventListener('click', function () { setMenu(true); });
        menuClose.addEventListener('click', function () { setMenu(false); });
        menuOverlay.querySelector('.menu-scrim').addEventListener('click', function () { setMenu(false); });
        var menuLinks = menuOverlay.querySelectorAll('a');
        for (var mi = 0; mi < menuLinks.length; mi++) {
          menuLinks[mi].addEventListener('click', function () { setMenu(false); });
        }
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !menuOverlay.hidden) setMenu(false);
        });
      } catch (e) { /* 菜单失效不影响内容 */ }

      /* 3) 懒加载图片淡入 */
      try {
        var lazyImgs = document.querySelectorAll('img[loading="lazy"]');
        for (var li = 0; li < lazyImgs.length; li++) {
          (function (img) {
            if (img.complete) return;
            img.style.opacity = '0';
            img.style.transition = 'opacity 800ms cubic-bezier(0.16, 1, 0.3, 1)';
            img.addEventListener('load', function () { img.style.opacity = '1'; });
          })(lazyImgs[li]);
        }
      } catch (e) {}

      /* 4) data-autoplay="visible" 的视频：进入视口自动静音播放，离开暂停
            视频用 data-src 延迟加载：首次进入视口才下载，避免首屏拖大文件 */
      try {
        var isReducedV = false;
        try { isReducedV = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        var autoVideos = document.querySelectorAll('video[data-autoplay="visible"]');
        var loadVideo = function (v) { if (!v.src && v.dataset && v.dataset.src) v.src = v.dataset.src; };
        if (autoVideos.length && !isReducedV && 'IntersectionObserver' in window) {
          var videoIO = new IntersectionObserver(function (entries) {
            for (var vi = 0; vi < entries.length; vi++) {
              var v = entries[vi].target;
              if (entries[vi].isIntersecting) {
                loadVideo(v);
                var p = v.play();
                if (p && p.catch) p.catch(function () {});
              } else {
                v.pause();
              }
            }
          }, { threshold: 0.25 });
          for (var vo = 0; vo < autoVideos.length; vo++) videoIO.observe(autoVideos[vo]);
          /* IO 失效兜底：3 秒后仍未加载的视频直接加载（不自动播放，交给用户点播） */
          setTimeout(function () {
            for (var vf = 0; vf < autoVideos.length; vf++) loadVideo(autoVideos[vf]);
          }, 3000);
        } else {
          for (var ve = 0; ve < autoVideos.length; ve++) loadVideo(autoVideos[ve]);
        }
      } catch (e) {}

      /* 5) mailto 兜底：手机无邮件应用/部分内置浏览器点 mailto 毫无反应，
            点击时同步复制邮箱并浮出提示。不阻止默认行为，桌面照常打开邮件客户端。
            提示语模板在 body[data-toast-mail]，按页面语言输出。 */
      try {
        var toastTpl = document.body.getAttribute('data-toast-mail') || 'Copied {mail}';
        var copyText = function (t) {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(t).then(null, function () {});
            return;
          }
          var ta = document.createElement('textarea');
          ta.value = t;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
        };
        var toastTimer = null;
        var showToast = function (msg) {
          var el = document.getElementById('site-toast');
          if (!el) {
            el = document.createElement('div');
            el.id = 'site-toast';
            el.setAttribute('role', 'status');
            document.body.appendChild(el);
          }
          el.textContent = msg;
          el.classList.add('show');
          if (toastTimer) clearTimeout(toastTimer);
          toastTimer = setTimeout(function () { el.classList.remove('show'); }, 2600);
        };
        var mailLinks = document.querySelectorAll('[data-mail]');
        for (var ml = 0; ml < mailLinks.length; ml++) {
          (function (a) {
            a.addEventListener('click', function () {
              var mail = a.getAttribute('data-mail');
              copyText(mail);
              showToast(toastTpl.replace('{mail}', mail));
            });
          })(mailLinks[ml]);
        }
      } catch (e) {}
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
