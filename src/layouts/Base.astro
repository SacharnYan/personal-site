---
// 基础布局：精确复刻 Steve Jobs Archive
import '@fontsource/playfair-display/400.css';
import '@fontsource/noto-serif-sc/400.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = '思想名片', image = '/og-default.jpg' } = Astro.props;
const url = Astro.url;
const siteName = '思想名片';
const ogImage = url.origin + image;
const navItems = [
  { href: '/projects/', label: '项目' },
  { href: '/writing/', label: '写作' },
  { href: '/notes/', label: '随记' },
  { href: '/photos/', label: '照片' },
  { href: '/vlog/', label: '影像' },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      /* 只在支持 ES module 的浏览器里启用入场动画；老旧/兼容模式浏览器直接显示内容 */
      if ('noModule' in HTMLScriptElement.prototype) document.documentElement.classList.add('js');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="alternate icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={url.href} />
  </head>
  <body>
    <a href="#main" class="skip-link">跳到内容</a>

    <header class="site-header">
      <a href="/" class="logo" aria-label="首页">
        <img src="/logo-variants/logo-spiral.svg" alt="" class="logo-mark" />
      </a>
      <button type="button" class="menu-toggle" aria-expanded="false" aria-controls="site-menu">
        Menu
        <svg class="menu-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
          <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </button>
    </header>

    <div class="menu-overlay" id="site-menu" hidden>
      <div class="menu-scrim"></div>
      <div class="menu-panel">
        <div class="menu-panel-head">
          <a href="/" class="logo" aria-label="首页">
            <img src="/logo-variants/logo-spiral.svg" alt="" class="logo-mark" />
          </a>
          <button type="button" class="menu-close">Close</button>
        </div>
        <nav class="menu-nav" aria-label="全站菜单">
          <ul class="menu-list">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="menu-link">{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
        <ul class="menu-foot">
          <li><a href="/about/" class="menu-foot-link">关于</a></li>
          <li><a href="mailto:sacharn@163.com" class="menu-foot-link">联系</a></li>
        </ul>
      </div>
    </div>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-news">
        <p class="footer-news-text">订阅更新。有新项目或文章时，我会写邮件告诉你。</p>
        <a href="mailto:sacharn@163.com?subject=订阅思想名片更新" class="footer-arrow" aria-label="邮件订阅">
          <svg width="16" height="12" viewBox="0 0 16 12" fill="none" aria-hidden="true">
            <path d="M1 6h13M10 1.5L14.5 6 10 10.5" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </a>
      </div>
      <div class="footer-base">
        <p class="footer-copy">© {new Date().getFullYear()} 严树成</p>
        <ul class="footer-links">
          <li><a href="/about/" class="footer-link">关于</a></li>
          <li><a href="mailto:sacharn@163.com" class="footer-link">联系</a></li>
          <li><a href="https://github.com/SacharnYan" class="footer-link" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
        <a href="#" class="footer-link footer-top" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">返回顶部</a>
      </div>
    </footer>

    <script>
      /* 结构原则：淡入显示是最高优先级，放在最前并独立防护；
         任何后续逻辑（菜单/图片/视频）报错都不能影响内容显示。
         兼容老内核：不用 NodeList.forEach、不裸调 matchMedia。 */

      /* 1) 淡入显示（最高优先级） */
      (function () {
        try {
          var allFade = document.querySelectorAll('[data-fade]');
          var isReduced = false;
          try { isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
          var showAll = function () {
            for (var i = 0; i < allFade.length; i++) allFade[i].classList.add('is-visible');
          };
          if (isReduced || !('IntersectionObserver' in window)) {
            showAll();
          } else {
            var fadeIO = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  fadeIO.unobserve(entry.target);
                }
              });
            }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
            for (var i = 0; i < allFade.length; i++) fadeIO.observe(allFade[i]);
          }
        } catch (e) {
          /* 任何异常：立即移除 js 标记，CSS 层恢复全部可见 */
          document.documentElement.classList.remove('js');
        }
      })();

      /* 2) SJA 式 Menu：全屏菜单开关 */
      try {
        const menuToggle = document.querySelector('.menu-toggle');
        const menuOverlay = document.querySelector('.menu-overlay');
        const menuClose = document.querySelector('.menu-close');
        const setMenu = (open) => {
          menuToggle.setAttribute('aria-expanded', String(open));
          if (open) {
            menuOverlay.hidden = false;
            requestAnimationFrame(() => requestAnimationFrame(() => menuOverlay.classList.add('is-open')));
            document.body.style.overflow = 'hidden';
          } else {
            menuOverlay.classList.remove('is-open');
            document.body.style.overflow = '';
            setTimeout(() => { menuOverlay.hidden = true; }, 450);
          }
        };
        menuToggle.addEventListener('click', () => setMenu(true));
        menuClose.addEventListener('click', () => setMenu(false));
        menuOverlay.querySelector('.menu-scrim').addEventListener('click', () => setMenu(false));
        menuOverlay.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !menuOverlay.hidden) setMenu(false);
        });
      } catch (e) { /* 菜单失效不影响内容 */ }

      /* 3) 懒加载图片淡入 */
      try {
        document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
          if (img.complete) return;
          img.style.opacity = '0';
          img.style.transition = 'opacity 800ms cubic-bezier(0.16, 1, 0.3, 1)';
          img.addEventListener('load', () => { img.style.opacity = '1'; }, { once: true });
        });
      } catch (e) {}

      /* 4) data-autoplay="visible" 的视频：进入视口自动静音播放，离开暂停
            视频用 data-src 延迟加载：首次进入视口才下载，避免首屏拖大文件 */
      try {
        var isReducedV = false;
        try { isReducedV = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        const autoVideos = document.querySelectorAll('video[data-autoplay="visible"]');
        if (autoVideos.length && !isReducedV && 'IntersectionObserver' in window) {
          const videoIO = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              const v = entry.target;
              if (entry.isIntersecting) {
                if (!v.src && v.dataset.src) v.src = v.dataset.src;
                v.play().catch(() => {});
              } else {
                v.pause();
              }
            });
          }, { threshold: 0.25 });
          autoVideos.forEach((v) => videoIO.observe(v));
        } else {
          autoVideos.forEach((v) => { if (!v.src && v.dataset.src) v.src = v.dataset.src; });
        }
      } catch (e) {}
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
