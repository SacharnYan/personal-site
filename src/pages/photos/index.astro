---
import Base from '../../layouts/Base.astro';

const photos = Array.from({ length: 9 }, (_, i) => ({
  src: `/photos/photo-${String(i + 1).padStart(2, '0')}.jpg`,
}));
---

<Base title="照片">
  <article class="article">
    <header class="article-hero" data-fade>
      <p class="article-eyebrow">Photos</p>
      <h1 class="article-title">照片</h1>
    </header>

    <div class="gallery">
      {photos.map((photo, i) => (
        <figure class="gallery-item" data-fade>
          <img
            src={photo.src}
            alt=""
            loading={i < 4 ? 'eager' : 'lazy'}
          />
        </figure>
      ))}
    </div>
  </article>
</Base>

<style>
  .article {
    max-width: none;
    margin: 0;
    padding: 0 0 160px 96px;
  }

  .article-hero {
    padding: 160px 0 96px;
  }

  .article-eyebrow {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 22px;
    letter-spacing: -0.28px;
    color: #707070;
    margin: 0 0 16px 0;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 60px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.2px;
    color: #000;
    max-width: 55ch;
    margin: 0;
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .gallery-item {
    margin: 0;
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .article {
      padding: 0 24px 80px;
    }

    .article-hero {
      padding: 120px 0 64px;
    }

    .article-title {
      font-size: 36px;
      line-height: 44px;
      letter-spacing: -0.72px;
    }

    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
