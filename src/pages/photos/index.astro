---
import Base from '../../layouts/Base.astro';
import photos from '../../data/photos.json';
---

<Base title="照片">
  <article class="article">
    <header class="article-hero" data-fade>
      <p class="article-eyebrow">Photos</p>
      <h1 class="article-title">照片</h1>
    </header>

    <div class="gallery">
      {photos.map((photo, i) => (
        <a class="gallery-item" data-fade href={`/photos/${photo.id}/`} aria-label={photo.title}>
          <img
            src={photo.src}
            alt={photo.title}
            loading={i < 4 ? 'eager' : 'lazy'}
          />
        </a>
      ))}
    </div>
  </article>
</Base>

<style>
  .article {
    max-width: none;
    margin: 0;
    padding: 0 96px 160px;
  }

  .article-hero {
    padding: 160px 0 96px;
  }

  .article-eyebrow {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 22px;
    letter-spacing: -0.28px;
    color: #707070;
    margin: 0 0 16px 0;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 60px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.2px;
    color: #000;
    max-width: 55ch;
    margin: 0;
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
  }

  .gallery-item {
    margin: 0;
    overflow: hidden;
    display: block;
    aspect-ratio: 4 / 5;
    transition: opacity 300ms ease;
  }

  .gallery-item:hover {
    opacity: 0.85;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .article {
      padding: 0 24px 80px;
    }

    .article-hero {
      padding: 120px 0 64px;
    }

    .article-title {
      font-size: 36px;
      line-height: 44px;
      letter-spacing: -0.72px;
    }

    .gallery {
      grid-template-columns: 1fr 1fr;
      gap: 6px;
    }
  }
</style>
