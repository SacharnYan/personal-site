---
import Base from '../layouts/Base.astro';

// 内容来源：data/index.json（首页内容）
// 你以后改首页内容，只改这个 JSON 文件就行
import sections from '../data/index.json';
---

<Base title="思想名片" description="一个安静的小站">
  <section class="hero container" data-fade>
    <p class="hero-eyebrow">严树成 · Nanjing</p>
    <h1 class="hero-title">
      终身学习者在自由市场创造性表达
    </h1>
    <p class="hero-sub">
      君子豹变，其文蔚也。
    </p>
  </section>

  <div class="container">
    {sections.map((section, i) => {
      // 照片六宫格
      if (section.type === 'photos') {
        return (
          <article class="block block-photos" data-fade>
            <div class="block-text">
              <p class="block-eyebrow">{section.eyebrow}</p>
              <h2 class="block-title">{section.title}</h2>
            </div>
            <div class="photo-grid">
              {section.images.map((src, j) => (
                <img
                  src={src}
                  alt=""
                  class="photo-grid-img"
                  loading={j < 4 ? 'eager' : 'lazy'}
                />
              ))}
            </div>
            {section.cta && (
              <a href={section.cta.href} class="block-cta">
                {section.cta.label}
              </a>
            )}
          </article>
        );
      }

      // 普通文本/图文块
      return (
        <article class="block" class:list={[{ 'block-with-image': section.image }, { 'is-first': i === 0 }]} data-fade>
          <div class="block-text">
            <p class="block-eyebrow">{section.eyebrow}</p>
            <h2 class="block-title">{section.title}</h2>
            {section.sub && <p class="block-sub">{section.sub}</p>}
            {section.cta && (
              <a href={section.cta.href} class="block-cta">
                {section.cta.label}
              </a>
            )}
          </div>
          {section.image && (
            <figure class="block-figure">
              <img
                src={section.image}
                alt={section.image_alt || ''}
                loading={i < 2 ? 'eager' : 'lazy'}
              />
            </figure>
          )}
        </article>
      );
    })}
  </div>
</Base>

<style>
  .hero-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-3);
  }

  .hero-title {
    font-size: 3.25rem;  /* 52px */
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    max-width: 12ch;
    margin-bottom: var(--space-3);
  }

  .hero-sub {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  /* 通用 block */
  .block {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
  }

  .block-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-1);
  }

  .block-title {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .block-sub {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-3);
  }

  .block-cta {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 1px;
    transition: color 200ms, border-color 200ms;
  }

  .block-cta:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .block-figure {
    margin: var(--space-4) 0;
    width: 100%;
    max-width: 480px;
  }
  .block-figure img {
    width: 100%;
    height: auto;
    border: 1px solid var(--color-rule);
    display: block;
  }

  /* 照片六宫格 */
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 4px;
    margin: var(--space-4) 0;
    max-width: 540px;
  }

  .photo-grid-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-rule);
  }

  /* 大屏：带图的 block 左右并排 */
  @media (min-width: 1024px) {
    .block-with-image {
      display: flex;
      flex-direction: row;
      gap: 48px;
      align-items: center;
    }
    .block-with-image .block-text {
      flex: 1;
      min-width: 0;
    }
    .block-with-image .block-figure {
      flex: 0 0 35%;
      max-width: 360px;
      margin: 0;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.25rem;  /* 36px */
    }
    .block-figure {
      max-width: 75%;
      margin-left: auto;
      margin-right: auto;
    }
    .photo-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 3px;
      max-width: 100%;
    }
  }
</style>
