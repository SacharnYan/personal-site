---
import Base from '../layouts/Base.astro';
import sections from '../data/index.json';
---

<Base title="思想名片" description="严树成的个人网站。写作、项目、照片、随记。">
  <section class="hero" data-fade>
    <div class="hero-inner">
      <h1 class="hero-title">终身学习，认真创造，自由表达。</h1>
      <p class="hero-subtitle">君子豹变，其文蔚也。</p>
    </div>
  </section>

  <div class="modules">
    {sections.map((section) => (
      <article class="module" data-fade>
        <div class="module-grid">
          <div class="module-copy">
            <p class="module-eyebrow">{section.eyebrow}</p>
            <hgroup class="module-headline">
              <h2 class="module-title">{section.title}</h2>
              {section.sub && <p class="module-subtitle">{section.sub}</p>}
            </hgroup>
            {section.cta && (
              <a href={section.cta.href} class="module-cta">
                {section.cta.label}
              </a>
            )}
          </div>

          <div class="module-media">
            {section.images ? (
              <div class="photo-grid">
                {section.images.map((src, j) => (
                  <img
                    src={src}
                    alt=""
                    class="photo-grid-img"
                    loading={j < 4 ? 'eager' : 'lazy'}
                  />
                ))}
              </div>
            ) : section.image ? (
              <figure class="module-figure">
                {section.is_video ? (
                  <video
                    data-src={section.image}
                    poster={section.poster}
                    preload="none"
                    playsinline
                    muted
                    loop
                    class="module-video"
                    data-autoplay="visible"
                  >
                    您的浏览器不支持视频播放。
                  </video>
                ) : (
                  <img
                    src={section.image}
                    alt={section.image_alt || ''}
                    loading="lazy"
                  />
                )}
              </figure>
            ) : null}
          </div>
        </div>
      </article>
    ))}
  </div>
</Base>

<style>
  /* ===== Hero ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 96px 12vh;
    margin-top: 0;
  }

  .hero-inner {
    max-width: 1248px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 54px;
    font-weight: 400;
    line-height: 70.2px;
    letter-spacing: -1.08px;
    color: #000;
    margin: 0 0 24px 0;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 400;
    line-height: 50.4px;
    letter-spacing: -0.84px;
    color: #707070;
    margin: 0;
  }

  /* ===== Modules ===== */
  .modules {
    border-top: 1px solid #d0d0d0;
  }

  .module {
    border-bottom: 1px solid #d0d0d0;
  }

  .module-grid {
    max-width: 1920px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(30, minmax(0, 1fr));
    column-gap: 0;
    row-gap: 0;
  }

  .module-copy {
    grid-column: 3 / 16;
    padding: 96px 0;
  }

  .module-media {
    grid-column: 17 / 29;
    padding: 96px 0;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .module-eyebrow {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    line-height: 37.7px;
    letter-spacing: -0.26px;
    color: #000;
    margin: 0 0 10px 0;
  }

  .module-headline {
    margin: 0 0 32px 0;
  }

  .module-title {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 400;
    line-height: 50.4px;
    letter-spacing: -0.84px;
    color: #000;
    margin: 0;
  }

  .module-subtitle {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 400;
    line-height: 50.4px;
    letter-spacing: -0.84px;
    color: #707070;
    margin: 0;
  }

  .module-title + .module-subtitle {
    margin-top: 0;
  }

  .module-cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.36px;
    color: #000;
    background: #f5f5f5;
    padding: 10px 23px;
    border-radius: 60px;
    transition: background 200ms, color 200ms;
  }

  .module-cta:hover {
    background: #000;
    color: #fff;
  }

  .module-figure {
    margin: 0;
    width: 100%;
  }

  .module-figure img {
    width: 100%;
    height: auto;
    display: block;
  }

  .module-figure video {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 4px;
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  .photo-grid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1248px) {
    .hero {
      padding: 0 48px 12vh;
    }

    .module-grid {
      grid-template-columns: 1fr 1fr;
    }

    .module-copy {
      grid-column: 1 / 2;
      padding: 64px 0 64px 48px;
    }

    .module-media {
      grid-column: 2 / 3;
      padding: 64px 48px 64px 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
      padding: 0 24px 14vh;
    }

    .hero-title {
      font-size: 32px;
      line-height: 42px;
      letter-spacing: -0.64px;
    }

    .hero-subtitle {
      font-size: 26px;
      line-height: 32px;
      letter-spacing: -0.52px;
    }

    .module-grid {
      grid-template-columns: 1fr;
    }

    .module-copy,
    .module-media {
      grid-column: 1 / 2;
      padding: 48px 24px;
    }

    .module-media {
      padding-top: 0;
    }

    .module-eyebrow {
      font-size: 18px;
      line-height: 26px;
    }

    .module-title,
    .module-subtitle {
      font-size: 26px;
      line-height: 32px;
      letter-spacing: -0.52px;
    }
  }
</style>
