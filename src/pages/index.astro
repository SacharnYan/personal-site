---
import Base from '../layouts/Base.astro';
import sections from '../data/index.json';
---

<Base title="思想名片" description="严树成的个人网站。写作、项目、照片、随记。">
  <section class="hero" data-fade>
    <div class="container hero-inner">
      <h1 class="hero-title">
        终身学习者在自由市场创造性表达。
      </h1>
      <p class="hero-lead">
        这是严树成的个人网站。项目、写作、照片和随记，都作为新起点，留给未来会路过这里的人。
      </p>
    </div>
  </section>

  <div class="container blocks">
    {sections.map((section) => {
      // 照片六宫格：左文字，右照片墙
      if (section.type === 'photos' || section.images) {
        return (
          <article class="block block-split" data-fade>
            <div class="block-text">
              <p class="block-eyebrow">{section.eyebrow}</p>
              <h2 class="block-title">{section.title}</h2>
              {section.sub && <p class="block-sub">{section.sub}</p>}
              {section.cta && (
                <a href={section.cta.href} class="block-button">
                  {section.cta.label}
                </a>
              )}
            </div>
            <div class="block-media">
              <div class="photo-grid">
                {section.images.map((src, j) => (
                  <img
                    src={src}
                    alt=""
                    class="photo-grid-img"
                    loading={j < 4 ? 'eager' : 'lazy'}
                  />
                ))}
              </div>
            </div>
          </article>
        );
      }

      // 普通图文块：有图则左右分栏，无图则单列
      return (
        <article class="block" class:list={[{ 'block-split': section.image }]} data-fade>
          <div class="block-text">
            <p class="block-eyebrow">{section.eyebrow}</p>
            <h2 class="block-title">{section.title}</h2>
            {section.sub && <p class="block-sub">{section.sub}</p>}
            {section.cta && (
              <a href={section.cta.href} class="block-button">
                {section.cta.label}
              </a>
            )}
          </div>
          {section.image && (
            <div class="block-media">
              <figure class="block-figure">
                {section.is_video ? (
                  <video
                    src={section.image}
                    preload="metadata"
                    playsinline
                    muted
                    loop
                    class="block-video"
                    data-autoplay="visible"
                  >
                    您的浏览器不支持视频播放。
                  </video>
                ) : (
                  <img
                    src={section.image}
                    alt={section.image_alt || ''}
                    loading="lazy"
                  />
                )}
              </figure>
            </div>
          )}
        </article>
      );
    })}
  </div>
</Base>

<style>
  .hero {
    padding-block: var(--space-12) var(--space-16);
  }

  .hero-inner {
    max-width: 64rem;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4.2vw, 3.5rem);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: var(--leading-loose);
    max-width: var(--measure);
  }

  /* ===== blocks ===== */
  .blocks {
    padding-bottom: var(--space-16);
  }

  .block {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-rule);
  }

  .block-text {
    max-width: var(--measure);
  }

  .block-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-3);
  }

  .block-eyebrow:lang(zh),
  .block-eyebrow:not(:lang(en)) {
    text-transform: none;
  }

  .block-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .block-sub {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .block-button {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-bg);
    background: var(--color-fg);
    padding: var(--space-2) var(--space-3);
    transition: background 200ms, color 200ms;
  }

  .block-button:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .block-media {
    width: 100%;
  }

  .block-figure {
    margin: 0;
  }

  .block-figure img,
  .block-figure video {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-rule);
  }

  .block-video {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: #000;
  }

  /* 照片六宫格 */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    width: 100%;
  }

  .photo-grid-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-rule);
  }

  /* 大屏：左右分栏，左 38% 右 62% */
  @media (min-width: 1024px) {
    .block-split {
      display: grid;
      grid-template-columns: 38% 62%;
      gap: 48px;
      align-items: center;
    }

    .block-split .block-text {
      max-width: none;
      padding-right: var(--space-4);
    }

    .block-split .block-media {
      max-width: 640px;
      justify-self: end;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: var(--space-8) var(--space-12);
    }

    .hero-title {
      font-size: 2rem;
      letter-spacing: -0.01em;
    }

    .block-title {
      font-size: 1.5rem;
    }

    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
