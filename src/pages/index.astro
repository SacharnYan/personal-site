---
import Base from '../layouts/Base.astro';
import sections from '../data/index.json';
---

<Base title="思想名片" description="严树成的个人网站。写作、项目、照片、随记。">
  <section class="hero" data-fade>
    <div class="container hero-inner">
      <h1 class="hero-title">
        终身学习者在自由市场创造性表达。
      </h1>
      <p class="hero-lead">
        这是严树成的个人网站。项目、写作、照片和随记，都作为新起点，留给未来会路过这里的人。
      </p>
    </div>
  </section>

  <div class="container blocks">
    {sections.map((section, i) => {
      // 照片六宫格
      if (section.type === 'photos' || section.images) {
        return (
          <article class="block" data-fade>
            <div class="block-meta">
              <p class="block-eyebrow">{section.eyebrow}</p>
              <h2 class="block-title">{section.title}</h2>
              {section.sub && <p class="block-sub">{section.sub}</p>}
              {section.cta && (
                <a href={section.cta.href} class="block-cta">
                  {section.cta.label}
                </a>
              )}
            </div>
            <div class="photo-grid">
              {section.images.map((src, j) => (
                <img
                  src={src}
                  alt=""
                  class="photo-grid-img"
                  loading={j < 4 ? 'eager' : 'lazy'}
                />
              ))}
            </div>
          </article>
        );
      }

      // 普通图文块
      return (
        <article class="block" class:list={[{ 'block-with-image': section.image }]} data-fade>
          <div class="block-meta">
            <p class="block-eyebrow">{section.eyebrow}</p>
            <h2 class="block-title">{section.title}</h2>
            {section.sub && <p class="block-sub">{section.sub}</p>}
            {section.cta && (
              <a href={section.cta.href} class="block-cta">
                {section.cta.label}
              </a>
            )}
          </div>
          {section.image && (
            <figure class="block-figure">
              {section.is_video ? (
                <video
                  src={section.image}
                  preload="metadata"
                  playsinline
                  muted
                  loop
                  class="block-video"
                  data-autoplay="visible"
                >
                  您的浏览器不支持视频播放。
                </video>
              ) : (
                <img
                  src={section.image}
                  alt={section.image_alt || ''}
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              )}
            </figure>
          )}
        </article>
      );
    })}
  </div>
</Base>

<style>
  .hero {
    padding-block: var(--space-12) var(--space-16);
  }

  .hero-inner {
    max-width: 64rem;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4.2vw, 3.5rem);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: var(--leading-loose);
    max-width: var(--measure);
  }

  /* ===== blocks ===== */
  .blocks {
    padding-bottom: var(--space-16);
  }

  .block {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-rule);
  }

  .block-meta {
    max-width: var(--measure);
  }

  .block-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-3);
  }

  .block-eyebrow:lang(zh),
  .block-eyebrow:not(:lang(en)) {
    text-transform: none;
  }

  .block-title {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .block-sub {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-3);
  }

  .block-cta {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-fg);
    padding-bottom: 1px;
    transition: color 200ms, border-color 200ms;
  }

  .block-cta:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .block-figure {
    margin: var(--space-4) 0 0;
    width: 100%;
  }

  .block-figure img,
  .block-figure video {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-rule);
  }

  .block-video {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: #000;
  }

  /* 照片六宫格 */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-top: var(--space-4);
    max-width: 720px;
  }

  .photo-grid-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-rule);
  }

  /* 大屏：带图 block 左右并排 */
  @media (min-width: 1024px) {
    .block-with-image {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }

    .block-with-image .block-meta {
      padding-top: var(--space-2);
    }

    .block-with-image .block-figure {
      margin: 0;
      max-width: 560px;
      justify-self: end;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: var(--space-8) var(--space-12);
    }

    .hero-title {
      font-size: 2.25rem;
      letter-spacing: -0.01em;
    }

    .block-title {
      font-size: 1.5rem;
    }

    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }

    .block-figure {
      max-width: 100%;
    }
  }
</style>
