---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const fmt = (d) => {
  const date = new Date(d);
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
};

export async function getStaticPaths() {
  const articles = await getCollection('writing', ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---

<Base
  title={`${article.data.title} — 写作`}
  description={article.data.description || article.data.title}
>
  <article class="container measure article-page" data-fade>
    <header class="article-header">
      <p class="article-date">{fmt(article.data.date)}</p>
      <h1 class="article-title">{article.data.title}</h1>
      {article.data.tags && (
        <div class="article-tags">
          {article.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <hr class="rule" />

    <div class="article-body">
      <Content />
    </div>
  </article>
</Base>

<style>
  .article-page {
    padding-top: var(--space-4);
  }

  .article-header {
    margin-bottom: var(--space-6);
  }

  .article-date {
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-3);
  }

  .article-header .article-title {
    font-size: var(--text-2xl);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-3);
  }

  .article-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  .tag {
    font-size: var(--text-xs);
    letter-spacing: 0.03em;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-rule);
    padding: 2px 8px;
  }

  .article-body {
    font-family: var(--font-display);
    line-height: var(--leading-loose);
  }

  .article-body h2 {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-rule);
  }

  .article-body h3 {
    font-size: var(--text-lg);
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .article-body p {
    margin-bottom: var(--space-4);
    line-height: var(--leading-loose);
  }

  .article-body hr {
    border: 0;
    border-top: 1px solid var(--color-rule);
    margin: var(--space-12) 0;
  }

  .article-body ul,
  .article-body ol {
    margin-bottom: var(--space-4);
    padding-left: var(--space-4);
  }

  .article-body li {
    line-height: var(--leading-loose);
    margin-bottom: var(--space-2);
    list-style: disc;
  }

  .article-body strong {
    font-weight: 600;
  }

  .article-body blockquote {
    border-left: 2px solid var(--color-rule);
    padding-left: var(--space-3);
    margin: var(--space-6) 0;
    color: var(--color-fg-muted);
  }

  .article-body blockquote p {
    margin-bottom: var(--space-2);
  }
</style>
