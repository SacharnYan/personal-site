---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const fmt = (d) => {
  const date = new Date(d);
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
};

const articles = await getCollection('writing', ({ data }) => !data.draft);
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="写作">
  <article class="container writing-page">
    <header class="writing-header" data-fade>
      <h1>写作</h1>
      <p class="text-muted text-sm">关于重复劳动怎么被自动化、我怎么学新东西的笔记。</p>
    </header>

    {articles.length === 0 && (
      <p class="text-muted">还没有文章，但会有的。</p>
    )}

    <div class="article-list">
      {articles.map((article, i) => (
        <section class="article-item" data-fade>
          <p class="article-date">{fmt(article.data.date)}</p>
          <h2 class="article-title">
            <a href={`/writing/${article.slug}/`}>{article.data.title}</a>
          </h2>
          {article.data.description && (
            <p class="article-desc">{article.data.description}</p>
          )}
          {article.data.tags && (
            <div class="article-tags">
              {article.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  </article>
</Base>

<style>
  .writing-header {
    padding-block: var(--space-4) var(--space-8);
  }

  .writing-header h1 {
    margin-bottom: var(--space-2);
  }

  .article-item {
    margin-bottom: var(--space-6);
    max-width: var(--measure);
  }

  .article-date {
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-1);
  }

  .article-title {
    font-size: var(--text-lg);
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-1);
  }

  .article-title a {
    color: var(--color-fg);
    border-bottom: 1px solid transparent;
    transition: color 200ms, border-color 200ms;
  }

  .article-title a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .article-desc {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-2);
  }

  .article-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  .tag {
    font-size: var(--text-xs);
    letter-spacing: 0.03em;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-rule);
    padding: 2px 8px;
  }
</style>
