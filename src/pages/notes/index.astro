---
import Base from '../../layouts/Base.astro';
import notes from '../../data/notes.json';

const fmt = (d) => {
  const date = new Date(d);
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
};
---

<Base title="随记">
  <article class="container notes-page">
    <header class="notes-header" data-fade>
      <h1>随记</h1>
      <p class="text-muted text-sm">随手记下的东西。短的，碎的，刚想到的。</p>
    </header>

    <div class="notes-list">
      {notes.length === 0 && (
        <p class="text-muted">还没有内容，但会有的。</p>
      )}
      {notes.map((note, i) => (
        <section class="note-item" data-fade>
          <p class="note-date">{fmt(note.date)}</p>
          <div class="note-text">
            {note.text.split('\n').filter(l => l.trim()).map(line => (
              <p>{line.trim()}</p>
            ))}
          </div>
        </section>
      ))}
    </div>
  </article>
</Base>

<style>
  .notes-header {
    padding-block: var(--space-4) var(--space-8);
  }

  .notes-header h1 {
    margin-bottom: var(--space-2);
  }

  .note-item {
    margin-bottom: var(--space-8);
    max-width: var(--measure);
  }

  .note-date {
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-2);
  }

  .note-text p {
    line-height: var(--leading-loose);
    margin-bottom: var(--space-3);
  }
</style>
