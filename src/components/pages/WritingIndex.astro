---
import Base from '../../layouts/Base.astro';
import { t, href, fmtDate, type Lang } from '../../i18n/ui';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isEn = lang === 'en';

const articles = await getCollection('writing', ({ data }) => !data.draft);
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

/* 已有全文译文的 slug，英文列表不再挂 "In Chinese" 徽标 */
const enSlugs = new Set((await getCollection('writing-en')).map((e) => e.slug));
---

<Base title={t(lang, 'writing.title')} lang={lang}>
  <article class="article">
    <header class="article-hero" data-fade>
      <p class="article-eyebrow">Writing</p>
      <h1 class="article-title">{t(lang, 'writing.title')}</h1>
    </header>

    <div class="article-body">
      <div class="article-list">
        {articles.map((article) => (
          <section class="article-item" data-fade>
            <p class="article-date">{fmtDate(lang, article.data.date)}</p>
            <h2 class="article-item-title">
              <a href={href(lang, `/writing/${article.slug}/`)}>
                {isEn ? (article.data.title_en || article.data.title) : article.data.title}
              </a>
              {isEn && !enSlugs.has(article.slug) && <span class="article-badge">{t(lang, 'writing.badge')}</span>}
            </h2>
            {(isEn ? article.data.description_en : article.data.description) && (
              <p class="article-item-desc">{isEn ? article.data.description_en : article.data.description}</p>
            )}
          </section>
        ))}
      </div>
    </div>
  </article>
</Base>

<style>
  .article {
    max-width: none;
    margin: 0;
    padding: 0 0 160px 96px;
  }

  .article-hero {
    padding: 160px 0 96px;
  }

  .article-eyebrow {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 22px;
    letter-spacing: -0.28px;
    color: #707070;
    margin: 0 0 16px 0;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 60px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.2px;
    color: #000;
    max-width: 55ch;
    margin: 0;
  }

  .article-body {
    max-width: 70ch;
  }

  .article-item {
    padding: 48px 0;
    border-bottom: 1px solid #d0d0d0;
  }

  .article-item:first-child {
    border-top: 1px solid #d0d0d0;
  }

  .article-date {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 22px;
    letter-spacing: -0.28px;
    color: #707070;
    margin: 0 0 12px 0;
  }

  .article-item-title {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -0.84px;
    margin: 0 0 12px 0;
  }

  .article-item-title a {
    color: #000;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms, color 200ms;
  }

  .article-item-title a:hover {
    color: #707070;
    border-bottom-color: #707070;
  }

  .article-badge {
    display: inline-block;
    vertical-align: middle;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    line-height: 18px;
    letter-spacing: 0.04em;
    color: #707070;
    border: 1px solid #d0d0d0;
    border-radius: 20px;
    padding: 2px 10px;
    margin-left: 14px;
  }

  .article-item-desc {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 26px;
    color: #707070;
    margin: 0;
  }

  @media (max-width: 768px) {
    .article {
      padding: 0 24px 80px;
    }

    .article-hero {
      padding: 120px 0 64px;
    }

    .article-title {
      font-size: 36px;
      line-height: 44px;
      letter-spacing: -0.72px;
    }

    .article-item-title {
      font-size: 26px;
      line-height: 32px;
      letter-spacing: -0.52px;
    }

    .article-item-desc {
      font-size: 15px;
      line-height: 24px;
    }
  }
</style>
