---
import Base from '../../layouts/Base.astro';
import { t, href, type Lang } from '../../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
---

<Base title={`${t(lang, 'notfound.title')} · ${t(lang, 'site.name')}`} description="404" lang={lang}>
  <div class="nf" data-fade>
    <p class="nf-code">404</p>
    <h1 class="nf-title">{t(lang, 'notfound.title')}</h1>
    <p class="nf-sub">{t(lang, 'notfound.sub')}</p>
    <a class="nf-link" href={href(lang, '/')}>{t(lang, 'notfound.back')}</a>
  </div>
</Base>

<style>
  .nf {
    max-width: 640px;
    margin: 0 auto;
    padding: 200px 24px 200px;
    text-align: center;
  }

  .nf-code {
    font-family: var(--font-body);
    font-size: 14px;
    letter-spacing: 0.3em;
    color: var(--color-fg-faint);
    margin: 0 0 32px;
  }

  .nf-title {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-fg);
    margin: 0 0 24px;
  }

  .nf-sub {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-fg-muted);
    margin: 0 0 56px;
  }

  .nf-link {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-fg);
    padding-bottom: 2px;
    transition: opacity 200ms ease;
  }

  .nf-link:hover {
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .nf {
      padding: 140px 24px 140px;
    }

    .nf-title {
      font-size: 30px;
    }
  }
</style>
